# Database
DATABASE_URL=postgresql://curata:curata@localhost:5433/curata

# Auth mode: "none" (tailnet/local), "oauth" (Google/Microsoft via next-auth), or "clerk" (Clerk SaaS)
AUTH_MODE=none

# Required for AUTH_MODE=oauth only
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# NEXTAUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Required for AUTH_MODE=clerk only
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Optional branding overrides (defaults: "curata" / "Where your AI work lives")
# SITE_TITLE=
# SITE_DESCRIPTION=
# OG_TITLE=

# Kazam renderer binary path (auto-detected in Docker)
# KAZAM_BIN=/usr/local/bin/kazam

# Site data directory (Docker default: /data/sites, local dev: ./data/sites)
SITES_ROOT=./data/sites
