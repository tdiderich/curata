# Database
DATABASE_URL=postgresql://curata:curata@localhost:5433/curata

# Auth mode: "none" | "tailscale" | "oauth" | "clerk"
# - none: no auth, first org used (local dev)
# - tailscale: identity from Tailscale-User-Login header (tailscale serve)
# - oauth: Google/Microsoft via next-auth
# - clerk: Clerk authentication
AUTH_MODE=none

# Required for AUTH_MODE=oauth only
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# NEXTAUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Kazam renderer binary path (auto-detected in Docker)
# KAZAM_BIN=/usr/local/bin/kazam

# Site data directory (Docker default: /data/sites, local dev: ./data/sites)
SITES_ROOT=./data/sites
