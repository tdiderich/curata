{
  "name": "curata",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm generate && next build",
    "generate": "prisma generate && .bin/kazam sdk emit > src/generated/kazam.ts && .bin/kazam sdk emit-react > src/generated/kazam-renderer.tsx",
    "start": "prisma db push && next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "bash scripts/install-hooks.sh 2>/dev/null || true; bash scripts/install-kazam.sh 2>/dev/null || true"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "js-yaml": "^4.1.1",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.28",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
