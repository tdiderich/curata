#!/usr/bin/env bash
set -euo pipefail

# ── Block manual edits to kazam-generated files ──
GENERATED_FILES=(
  "src/app/kazam.css"
  "src/generated/kazam.ts"
  "src/generated/kazam-renderer.tsx"
  "docs/agents-reference.md"
)

staged=$(git diff --cached --name-only)
blocked=()
for f in "${GENERATED_FILES[@]}"; do
  if echo "$staged" | grep -qx "$f"; then
    blocked+=("$f")
  fi
done

if [ ${#blocked[@]} -gt 0 ]; then
  echo ""
  echo "BLOCKED: These files are generated by kazam — don't edit them directly."
  echo ""
  for f in "${blocked[@]}"; do
    echo "  • $f"
  done
  echo ""
  echo "To update:"
  echo "  1. Make changes in kazam (https://github.com/tdiderich/kazam)"
  echo "  2. Build: cargo build --release"
  echo "  3. Install the binary and regenerate: pnpm generate"
  echo ""
  echo "To bypass (rare): git commit --no-verify"
  exit 1
fi

echo "pre-commit: lint"
pnpm lint
